# Конфигурация deliver.py для сервера 192.168.251.190
# Загружается watchdog'ом: source deliver.env && python3 deliver.py
FRONTEND_DB_PORT=5435
FRONTEND_DB_HOST=localhost
FRONTEND_DB_USER=pikurr
FRONTEND_DB_PASSWORD=pikurr
FRONTEND_DB_NAME=pikurr

GEOSERVER_URL=http://localhost:8090/geoserver
GEOSERVER_USER=admin
GEOSERVER_PASSWORD=geoserver
GEOSERVER_WORKSPACE=pikurr
GEOSERVER_COVERAGESTORE=image_assessment

# Папка прилёта пакетов
PIKURR_INBOX=/home/user/repikurr/inbox
